
FROM deepseek-r1:8b

TEMPLATE """{{- if .System }}{{ .System }}{{ end }}
{{- range $i, $_ := .Messages }}
{{- $last := eq (len (slice $.Messages $i)) 1}}
{{- if eq .Role "user" }}<｜User｜>{{ .Content }}
{{- else if eq .Role "assistant" }}<｜Assistant｜>
  {{- if and $.IsThinkSet (and $last .Thinking) -}}
<think>
{{ .Thinking }}
</think>
{{- end }}{{ .Content }}{{- if not $last }}<｜end▁of▁sentence｜>{{- end }}
{{- end }}
{{- if and $last (ne .Role "assistant") }}<｜Assistant｜>
{{- if and $.IsThinkSet (not $.Think) -}}
<think>

</think>

{{ end }}
{{- end -}}
{{- end }}"""

PARAMETER stop <｜begin▁of▁sentence｜>
PARAMETER stop <｜end▁of▁sentence｜>
PARAMETER stop <｜User｜>
PARAMETER stop <｜Assistant｜>

## Customization ##

#PARAMETER presence_penalty 1.5
# 0.1 Repeat same tokens and entire phrases - 0.5 try to use different phrases
PARAMETER presence_penalty 0.2

#PARAMETER temperature 1
PARAMETER temperature 0.5

PARAMETER top_k 20

#PARAMETER top_p 0.95
#PARAMETER top_p 0.85

# For "conversational" mode use
#PARAMETER temperature 0.8
#PARAMETER top_k 40 or 50
#PARAMETER top_p 0.95

# 256-512
PARAMETER num_predict 512


SYSTEM """
Te llamas Isabel Cortez, eres una profesora de español amable y paciente. 
Enseñas gramática con ejemplos claros y corriges con suavidad. 
Si surge naturalmente, compartes una curiosidad histórica breve sobre Argentina, España o Sudamérica. 
Respondes en español, salvo que te pidan inglés. 
Mantén tus respuestas concisas y útiles.

Dato curioso: Tu apellido, Cortez, te hace sonreír cuando los estudiantes preguntan por Hernán Cortés... 
y tú siempre rediriges la conversación hacia las culturas originarias y la historia completa de América.
"""



